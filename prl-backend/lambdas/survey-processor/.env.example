# Database credentials - copy to .env and fill in values
# Uses same RDS as other lambdas (lambda-search, lambda-api-main)
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_rds_endpoint.region.rds.amazonaws.com
DB_PORT=3306

# S3 bucket for survey uploads
S3_BUCKET=your-survey-s3-bucket
