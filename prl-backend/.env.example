# Infrastructure identifiers — required for CDK synth/deploy
PRL_S3_BUCKET=your-public-s3-bucket
PRL_SURVEY_S3_BUCKET=your-survey-s3-bucket
PRL_CLOUDFRONT_DIST_ID=your-cloudfront-distribution-id
PRL_S3_INTERNAL_BUCKET=your-internal-s3-bucket
PRL_S3_TWITTER_IMAGES_BUCKET=your-twitter-images-s3-bucket

# Runtime env vars — set by CDK for Lambda/ECS; only needed for local dev/scripts
S3_BUCKET=your-public-s3-bucket
SURVEY_S3_BUCKET=your-survey-s3-bucket
S3_INTERNAL_BUCKET=your-internal-s3-bucket
S3_TWITTER_IMAGES_BUCKET=your-twitter-images-s3-bucket

# Pulse API runtime
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# Monitoring stack
PULSE_API_FUNCTION_NAME=your-pulse-api-function-name

# Search API (only needed for deploy.sh)
SEARCH_API_URL=https://your-search-api.execute-api.us-east-1.amazonaws.com

# Scripts
DATA_API_URL=https://your-data-api.execute-api.us-east-1.amazonaws.com/default
